{
  "name": "tere-studio-portal",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "tsc -b --noEmit",
    "start": "node serve.mjs",
    "check:serve": "node --check serve.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "lucide-react": "0.487.0",
    "onnxruntime-web": "1.20.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "sharp": "^0.35.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.6.3",
    "vite": "4.5.14"
  }
}
