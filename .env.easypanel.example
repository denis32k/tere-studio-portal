# EasyPanel — Terê Studio Portal (prévia mobile)
# App/domínio: https://minhaloja.terepersonalizados.com.br
# Porta interna do app: 8080

PORT=8080
NODE_ENV=production

# URL pública do tere-license-server (o mesmo backend do painel admin/licenças).
# É usada em tempo de BUILD (o Vite grava esse valor dentro do JS gerado), não em runtime —
# se mudar, precisa rodar o build de novo, não só reiniciar o app.
VITE_LICENSE_SERVER_URL=https://li.terepersonalizados.com.br/api
